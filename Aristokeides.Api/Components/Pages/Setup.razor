@page "/setup"
@using Aristokeides.Api.Models
@using Aristokeides.Api.Services
@inject SetupService SetupService
@inject NavigationManager NavigationManager

<PageTitle>Aristokeides Setup</PageTitle>

<div class="setup-container">
    <div class="setup-card">
        <h2 class="setup-title">Aristokeides Installation</h2>
        <p class="setup-description">Choose your database and create the initial admin account.</p>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger">@ErrorMessage</div>
        }

        <EditForm Model="Model" OnValidSubmit="HandleSetup" FormName="setupForm">
            <DataAnnotationsValidator />

            <div class="form-section">
                <h3>1. Database Configuration</h3>
                <div class="form-group">
                    <label>Database Type</label>
                    <InputSelect @bind-Value="Model.DatabaseProvider" class="form-select">
                        <option value="SQLite">SQLite (Recommended for simple setups)</option>
                        <option value="PostgreSQL">PostgreSQL</option>
                        <option value="MySQL">MySQL / MariaDB</option>
                    </InputSelect>
                </div>

                @if (Model.DatabaseProvider == "SQLite")
                {
                    <div class="form-group">
                        <label>Database File Path</label>
                        <InputText @bind-Value="Model.SqliteFilePath" class="form-input" />
                        <span class="help-text">Default is aristokeides.db in the app directory.</span>
                    </div>
                }
                else
                {
                    <div class="form-row">
                        <div class="form-group col-70">
                            <label>Host</label>
                            <InputText @bind-Value="Model.DbHost" class="form-input" />
                        </div>
                        <div class="form-group col-30">
                            <label>Port</label>
                            <InputNumber @bind-Value="Model.DbPort" class="form-input" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Database Name</label>
                        <InputText @bind-Value="Model.DbName" class="form-input" />
                    </div>
                    <div class="form-row">
                        <div class="form-group col-50">
                            <label>Username</label>
                            <InputText @bind-Value="Model.DbUsername" class="form-input" />
                        </div>
                        <div class="form-group col-50">
                            <label>Password</label>
                            <InputText @bind-Value="Model.DbPassword" type="password" class="form-input" />
                        </div>
                    </div>
                }
            </div>

            <div class="form-section">
                <h3>2. Administrator Account</h3>
                <div class="form-group">
                    <label>Username</label>
                    <InputText @bind-Value="Model.AdminUsername" class="form-input" />
                    <ValidationMessage For="@(() => Model.AdminUsername)" />
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <InputText @bind-Value="Model.AdminEmail" type="email" class="form-input" />
                    <ValidationMessage For="@(() => Model.AdminEmail)" />
                </div>
                <div class="form-row">
                    <div class="form-group col-50">
                        <label>Password</label>
                        <InputText @bind-Value="Model.AdminPassword" type="password" class="form-input" />
                        <ValidationMessage For="@(() => Model.AdminPassword)" />
                    </div>
                    <div class="form-group col-50">
                        <label>Confirm Password</label>
                        <InputText @bind-Value="Model.AdminPasswordConfirm" type="password" class="form-input" />
                        <ValidationMessage For="@(() => Model.AdminPasswordConfirm)" />
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary btn-block" disabled="@IsLoading">
                    @if (IsLoading)
                    {
                        <span>Installing... Please wait.</span>
                    }
                    else
                    {
                        <span>Install Aristokeides</span>
                    }
                </button>
            </div>
        </EditForm>
    </div>
</div>

<style>
    body { background-color: #f6f8fa; }
    .setup-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        padding: 2rem;
    }
    .setup-card {
        background: #ffffff;
        border: 1px solid #d0d7de;
        border-radius: 6px;
        padding: 2rem;
        max-width: 600px;
        width: 100%;
        box-shadow: 0 3px 6px rgba(140, 149, 159, 0.15);
    }
    .setup-title {
        font-size: 24px;
        margin-top: 0;
        margin-bottom: 0.5rem;
        text-align: center;
    }
    .setup-description {
        color: #57606a;
        text-align: center;
        margin-bottom: 2rem;
    }
    .form-section {
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid #d0d7de;
    }
    .form-section h3 {
        font-size: 16px;
        margin-bottom: 1rem;
        color: #24292f;
    }
    .form-group {
        margin-bottom: 1rem;
    }
    .form-group label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 600;
        font-size: 14px;
    }
    .form-input, .form-select {
        width: 100%;
        padding: 5px 12px;
        font-size: 14px;
        line-height: 20px;
        color: #24292f;
        vertical-align: middle;
        background-color: #ffffff;
        border: 1px solid #d0d7de;
        border-radius: 6px;
        box-sizing: border-box;
    }
    .form-input:focus, .form-select:focus {
        border-color: #0969da;
        outline: none;
        box-shadow: 0 0 0 3px rgba(9, 105, 218, 0.3);
    }
    .form-row {
        display: flex;
        gap: 1rem;
    }
    .col-70 { width: 70%; }
    .col-30 { width: 30%; }
    .col-50 { width: 50%; }
    .help-text {
        font-size: 12px;
        color: #57606a;
        margin-top: 4px;
        display: block;
    }
    .btn {
        display: inline-block;
        padding: 5px 16px;
        font-size: 14px;
        font-weight: 500;
        line-height: 20px;
        white-space: nowrap;
        vertical-align: middle;
        cursor: pointer;
        user-select: none;
        border: 1px solid;
        border-radius: 6px;
        appearance: none;
    }
    .btn-primary {
        color: #ffffff;
        background-color: #2da44e;
        border-color: rgba(27, 31, 36, 0.15);
    }
    .btn-primary:hover {
        background-color: #2c974b;
    }
    .btn-block {
        width: 100%;
        text-align: center;
        padding: 10px 16px;
        font-size: 16px;
    }
    .alert {
        padding: 10px;
        margin-bottom: 1rem;
        border-radius: 6px;
    }
    .alert-danger {
        color: #cf222e;
        background-color: #FFEBE9;
        border: 1px solid rgba(255, 129, 130, 0.4);
    }
    .validation-message {
        color: #cf222e;
        font-size: 12px;
        margin-top: 4px;
    }
</style>

@code {
    [SupplyParameterFromForm]
    public SetupViewModel Model { get; set; } = new();

    private string? ErrorMessage { get; set; }
    private bool IsLoading { get; set; }

    private async Task HandleSetup()
    {
        try
        {
            IsLoading = true;
            ErrorMessage = null;
            
            var success = await SetupService.InstallAsync(Model);
            if (success)
            {
                // Navigate home, app will stop. A simple reload will boot the installed app.
                NavigationManager.NavigateTo("/", forceLoad: true);
            }
            else
            {
                ErrorMessage = "Installation already completed.";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Installation failed: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }
}
