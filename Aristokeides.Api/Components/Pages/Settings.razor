    private async Task Initiate2FaSetup()
    {
        isSubmitting2Fa = true;
        errorMessage = null;
        successMessage = null;
        try
        {
            using var client = CreateHttpClient();
            var response = await client.GetFromJsonAsync<TwoFactorSetupResponse>("api/auth/2fa/setup");
            if (response != null)
            {
                tempSecretKey = response.Secret;
                otpAuthUri = response.OtpAuthUri;
                isSetupInitiated = true;

                StateHasChanged();
                await Task.Delay(100);
                await JSRuntime.InvokeVoidAsync("renderQrCode", "qrcode-container", otpAuthUri);
            }
        }
        catch
        {
            errorMessage = "2FA 설정을 시작하지 못했습니다.";
        }
        finally
        {
            isSubmitting2Fa = false;
        }
    }

    private void Cancel2FaSetup()
    {
        isSetupInitiated = false;
        tempSecretKey = null;
        otpAuthUri = null;
        otpVerificationCode = "";
        errorMessage = null;
    }

    private async Task Enable2FaAsync()
    {
        if (string.IsNullOrWhiteSpace(otpVerificationCode) || otpVerificationCode.Length != 6)
        {
            errorMessage = "올바른 6자리 OTP 코드를 입력해 주십시오.";
            return;
        }

        isSubmitting2Fa = true;
        errorMessage = null;
        try
        {
            using var client = CreateHttpClient();
            var request = new Enable2FaRequest(tempSecretKey!, otpVerificationCode);
            var response = await client.PostAsJsonAsync("api/auth/2fa/enable", request);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<Enable2FaResponse>();
                recoveryCodesToShow = result?.RecoveryCodes;
                isTwoFactorEnabled = true;
                isSetupInitiated = false;
                successMessage = "2단계 인증이 성공적으로 활성화되었습니다. 아래 백업 복구 코드를 반드시 보관하세요.";
            }
            else
            {
                var err = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                errorMessage = err?.Message ?? "OTP 코드 검증에 실패했습니다. 다시 시도하십시오.";
            }
        }
        catch
        {
            errorMessage = "2FA 활성화 중 오류가 발생했습니다.";
        }
        finally
        {
            isSubmitting2Fa = false;
        }
    }

    private async Task Disable2FaAsync()
    {
        if (string.IsNullOrWhiteSpace(confirmPassword))
        {
            errorMessage = "비밀번호를 입력해야 합니다.";
            return;
        }

        isSubmitting2Fa = true;
        errorMessage = null;
        successMessage = null;
        try
        {
            using var client = CreateHttpClient();
            var request = new Disable2FaRequest(confirmPassword);
            var response = await client.PostAsJsonAsync("api/auth/2fa/disable", request);

            if (response.IsSuccessStatusCode)
            {
                isTwoFactorEnabled = false;
                confirmPassword = "";
                recoveryCodesToShow = null;
                successMessage = "2단계 인증이 비활성화되었습니다.";
            }
            else
            {
                var err = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                errorMessage = err?.Message ?? "비밀번호가 올바르지 않거나 비활성화하지 못했습니다.";
            }
        }
        catch
        {
            errorMessage = "2FA 비활성화 중 오류가 발생했습니다.";
        }
        finally
        {
            isSubmitting2Fa = false;
        }
    }

