    private async Task RevokeSessionAsync(string sessionId)
    {
        errorMessage = null;
        successMessage = null;

        var message = "이 기기를 로그아웃 시키겠습니까? 해당 기기에서 즉시 연결이 끊어집니다.";
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", message);
        if (!confirmed)
        {
            return;
        }

        try
        {
            using var client = CreateHttpClient();
            var response = await client.PostAsJsonAsync("api/auth/sessions/revoke", new RevokeSessionRequest(sessionId));
            if (response.IsSuccessStatusCode)
            {
                successMessage = "원격 세션이 성공적으로 종료되었습니다.";
                await LoadSessionsAsync();
