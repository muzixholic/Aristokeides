@page "/settings"
@using System.Net.Http.Json
@using Aristokeides.Api.Models
@using Aristokeides.Api.Controllers
@using Microsoft.JSInterop
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@rendermode Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer

<PageTitle>Settings</PageTitle>

<div style="max-width: 800px; margin: 32px auto; padding: 24px; background: var(--dominant, #FFFFFF); border: 1px solid #e5e7eb; border-radius: 8px;">
    <h1 style="font-size: 24px; font-weight: 600; margin-bottom: 24px;">사용자 설정</h1>

    <!-- Tab Navigation -->
    <div style="display: flex; border-bottom: 1px solid #e5e7eb; margin-bottom: 24px;">
        <button type="button" @onclick='() => SwitchTab("general")' style='padding: 8px 16px; border: none; background: @(activeTab == "general" ? "#f3f4f6" : "#FFFFFF"); color: @(activeTab == "general" ? "#2563eb" : "#4b5563"); border-bottom: @(activeTab == "general" ? "2px solid #2563eb" : "none"); font-weight: 600; cursor: pointer;'>
            일반 설정
        </button>
        <button type="button" @onclick='() => SwitchTab("ssh")' style='padding: 8px 16px; border: none; background: @(activeTab == "ssh" ? "#f3f4f6" : "#FFFFFF"); color: @(activeTab == "ssh" ? "#2563eb" : "#4b5563"); border-bottom: @(activeTab == "ssh" ? "2px solid #2563eb" : "none"); font-weight: 600; cursor: pointer;'>
            SSH 키
        </button>
        <button type="button" @onclick='() => SwitchTab("2fa")' style='padding: 8px 16px; border: none; background: @(activeTab == "2fa" ? "#f3f4f6" : "#FFFFFF"); color: @(activeTab == "2fa" ? "#2563eb" : "#4b5563"); border-bottom: @(activeTab == "2fa" ? "2px solid #2563eb" : "none"); font-weight: 600; cursor: pointer;'>
            보안 및 2FA
        </button>
    </div>

    @if (activeTab == "general")
    {
        <!-- General Settings Tab Content -->
        <div>
            <h2 style="font-size: 18px; font-weight: 600; margin-bottom: 16px;">일반 설정</h2>
            <p style="color: #6b7280;">일반 프로필 설정 기능은 현재 준비 중입니다.</p>
        </div>
    }
    else if (activeTab == "ssh")
    {
        <!-- SSH Keys Tab Content -->
        <div>
            <h2 style="font-size: 18px; font-weight: 600; margin-bottom: 8px;">SSH 키 추가</h2>

            @if (errorMessage != null)
            {
                <div style="background-color: #fee2e2; color: #ef4444; padding: 12px; border-radius: 4px; margin-bottom: 16px; font-size: 14px; border: 1px solid #fca5a5;">
                    @errorMessage
                </div>
            }
            @if (successMessage != null)
            {
                <div style="background-color: #d1fae5; color: #065f46; padding: 12px; border-radius: 4px; margin-bottom: 16px; font-size: 14px; border: 1px solid #6ee7b7;">
                    @successMessage
                </div>
            }

            <form @submit:preventDefault="true" @onsubmit="RegisterKeyAsync">
                <div style="margin-bottom: 16px;">
                    <label for="key-name" style="display: block; font-size: 14px; font-weight: 600; margin-bottom: 8px;">키 이름</label>
                    <input type="text" id="key-name" @bind="newKeyName" disabled="@isSubmitting" placeholder="예: my-ssh-key-comment" style="width: 100%; padding: 8px; border: 1px solid #e5e7eb; border-radius: 4px; font-size: 14px;" />
                </div>

                <div style="margin-bottom: 16px;">
                    <label for="public-key" style="display: block; font-size: 14px; font-weight: 600; margin-bottom: 8px;">공개 키 (Public Key)</label>
                    <textarea id="public-key" @bind:event="oninput" @bind="newPublicKey" @onkeyup="HandleKeyInput" disabled="@isSubmitting" placeholder="'ssh-rsa', 'ssh-ed25519', 또는 'ecdsa-sha2-' 로 시작하는 전체 공개키 입력" rows="6" style="width: 100%; padding: 8px; border: 1px solid #e5e7eb; border-radius: 4px; font-family: monospace; font-size: 12px; resize: vertical;"></textarea>
                </div>

                <button type="submit" disabled="@isSubmitting" style="padding: 10px 20px; background: #2563eb; color: #FFFFFF; border: none; border-radius: 4px; font-weight: 600; cursor: @(isSubmitting ? "not-allowed" : "pointer"); opacity: @(isSubmitting ? 0.7 : 1);">
                    @(isSubmitting ? "추가 중..." : "SSH 키 추가")
                </button>
            </form>

            <hr style="border: 0; border-top: 1px solid #e5e7eb; margin: 32px 0;" />

            <div style="background-color: #eff6ff; color: #1e3a8a; padding: 16px; border-radius: 6px; margin-bottom: 24px; border: 1px solid #bfdbfe;">
                <h3 style="font-size: 15px; font-weight: 600; margin-bottom: 8px;">💡 SSH 설정 팁</h3>
                <p style="font-size: 13px; margin: 0 0 8px 0; line-height: 1.5;">
                    기본 SSH 키(예: <code style="background: #dbeafe; padding: 2px 4px; border-radius: 3px;">id_rsa</code> 또는 <code style="background: #dbeafe; padding: 2px 4px; border-radius: 3px;">id_ed25519</code>)가 아닌 커스텀 SSH 키를 사용하는 경우, SSH 클라이언트가 자동으로 해당 키를 제안하지 못해 패스워드 입력을 요구하거나 <strong>Permission denied</strong>로 연결이 실패할 수 있습니다.
                </p>
                <p style="font-size: 13px; margin: 0 0 12px 0; line-height: 1.5;">
                    이를 해결하려면 각 플랫폼별로 <code style="background: #dbeafe; padding: 2px 4px; border-radius: 3px;">config</code> 파일을 생성하거나 편집하고, <strong>IdentitiesOnly yes</strong> 옵션을 명시해 주시기 바랍니다.
                </p>
                
                <div style="display: flex; flex-direction: column; gap: 12px; font-size: 13px; margin-bottom: 12px;">
                    <div>
                        <strong>💻 Windows 설정 경로:</strong> <code style="background: #dbeafe; padding: 2px 4px; border-radius: 3px; font-family: monospace;">%USERPROFILE%\.ssh\config</code>
                    </div>
                    <div>
                        <strong>🍎 macOS / 🐧 Linux 설정 경로:</strong> <code style="background: #dbeafe; padding: 2px 4px; border-radius: 3px; font-family: monospace;">~/.ssh/config</code>
                    </div>
                </div>

                <div style="margin-bottom: 12px;">
                    <strong>⚙️ config 설정 템플릿 예시:</strong>
                    <pre style="background: #ffffff; border: 1px solid #bfdbfe; color: #1e3a8a; padding: 10px; border-radius: 4px; margin: 6px 0 0 0; font-family: monospace; font-size: 12px; line-height: 1.4;">Host localhost
  HostName localhost
  Port 2222
  User git
  IdentityFile ~/.ssh/id_ed25519  # 실제 키 경로로 수정
  IdentitiesOnly yes</pre>
                </div>

                <div>
                    <strong>🔍 진단 연결 테스트 (키 명시):</strong>
                    <pre style="background: #ffffff; border: 1px solid #bfdbfe; color: #1e3a8a; padding: 10px; border-radius: 4px; margin: 6px 0 0 0; font-family: monospace; font-size: 12px; line-height: 1.4;">ssh -i ~/.ssh/id_ed25519 -T git@localhost -p 2222 -o IdentitiesOnly=yes</pre>
                </div>
            </div>

            <h2 style="font-size: 18px; font-weight: 600; margin-bottom: 16px;">등록된 SSH 키 목록</h2>

            @if (isLoadingKeys)
            {
                <p style="color: #6b7280; font-size: 14px;">키 목록을 불러오는 중...</p>
            }
            else if (sshKeys.Count == 0)
            {
                <div style="padding: 48px 16px; text-align: center; background: #f9fafb; border: 1px dashed #e5e7eb; border-radius: 6px;">
                    <h3 style="font-size: 16px; font-weight: 600; margin-bottom: 8px; color: #374151;">등록된 키가 없습니다</h3>
                    <p style="color: #6b7280; font-size: 14px; margin: 0;">계정에 연결된 SSH 키가 없습니다. SSH 기반의 git 작업을 활성화하려면 키를 등록하십시오.</p>
                </div>
            }
            else
            {
                <div style="display: flex; flex-direction: column; gap: 16px;">
                    @foreach (var key in sshKeys)
                    {
                        <div style="padding: 16px; border: 1px solid #e5e7eb; border-radius: 6px; display: flex; justify-content: space-between; align-items: flex-start; background: #ffffff;">
                            <div>
                                <div style="font-weight: 600; font-size: 14px; margin-bottom: 4px;">
                                    🔑 @key.Label (@GetKeyType(key.PublicKey))
                                </div>
                                <div style="font-family: monospace; font-size: 12px; color: #6b7280; margin-bottom: 4px;">
                                    지문 (Fingerprint): @key.Fingerprint
                                </div>
                                <div style="font-size: 12px; color: #9ca3af;">
                                    등록일: @key.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                                </div>
                            </div>
                            <button type="button" @onclick="() => DeleteKeyAsync(key)" style="padding: 6px 12px; background: #ef4444; color: #ffffff; border: none; border-radius: 4px; font-size: 12px; font-weight: 600; cursor: pointer;">
                                삭제
                            </button>
                        </div>
                    }
                </div>
            }
        </div>
    }
    else if (activeTab == "2fa")
    {
        <!-- Security & 2FA Tab Content -->
        <div>
            <h2 style="font-size: 18px; font-weight: 600; margin-bottom: 16px;">보안 및 2차 인증 (Security & 2FA)</h2>

            @if (errorMessage != null)
            {
                <div style="background-color: #fee2e2; color: #ef4444; padding: 12px; border-radius: 4px; margin-bottom: 16px; font-size: 14px; border: 1px solid #fca5a5;">
                    @errorMessage
                </div>
            }
            @if (successMessage != null)
            {
                <div style="background-color: #d1fae5; color: #065f46; padding: 12px; border-radius: 4px; margin-bottom: 16px; font-size: 14px; border: 1px solid #6ee7b7;">
                    @successMessage
                </div>
            }

            @if (isLoading2Fa)
            {
                <p style="color: #6b7280; font-size: 14px;">설정 상태를 불러오는 중...</p>
            }
            else if (isTwoFactorEnabled)
            {
                <div style="background-color: #eff6ff; border: 1px solid #bfdbfe; border-radius: 6px; padding: 20px; margin-bottom: 24px;">
                    <h3 style="font-size: 16px; font-weight: 600; color: #1e3a8a; margin-top: 0; margin-bottom: 8px;">
                        🛡️ 2단계 인증(2FA)이 활성화되어 있습니다.
                    </h3>
                    <p style="font-size: 14px; color: #1e40af; margin: 0; line-height: 1.5;">
                        계정이 안전하게 보호받고 있습니다. 로그인 시 OTP 코드를 입력해야 합니다.
                    </p>
                </div>

                @if (recoveryCodesToShow != null && recoveryCodesToShow.Length > 0)
                {
                    <div style="background-color: #fffbeb; border: 1px solid #fde68a; border-radius: 6px; padding: 20px; margin-bottom: 24px;">
                        <h3 style="font-size: 15px; font-weight: 600; color: #92400e; margin-top: 0; margin-bottom: 8px;">
                            ⚠️ 중요: 2FA 백업 복구 코드
                        </h3>
                        <p style="font-size: 13px; color: #78350f; margin-bottom: 12px;">
                            휴대전화를 분실하거나 OTP 앱에 접근할 수 없을 때 아래 코드를 사용해 로그인할 수 있습니다. 
                            <strong>이 코드는 다시 표시되지 않으므로 반드시 안전한 곳에 인쇄하거나 복사하여 보관하십시오.</strong>
                        </p>
                        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; font-family: monospace; font-size: 14px; font-weight: bold; background: #ffffff; padding: 12px; border: 1px solid #f59e0b; border-radius: 4px; text-align: center;">
                            @foreach (var recoveryCode in recoveryCodesToShow)
                            {
                                <div>@recoveryCode</div>
                            }
                        </div>
                    </div>
                }

                <div style="border: 1px solid #e5e7eb; border-radius: 6px; padding: 20px;">
                    <h4 style="font-size: 15px; font-weight: 600; margin-top: 0; margin-bottom: 12px; color: #374151;">2단계 인증 비활성화</h4>
                    <p style="font-size: 13px; color: #6b7280; margin-bottom: 16px;">
                        2단계 인증을 해제하면 계정 보안이 취약해집니다. 계속 진행하려면 비밀번호를 입력하십시오.
                    </p>
                    <form @submit:preventDefault="true" @onsubmit="Disable2FaAsync">
                        <div style="margin-bottom: 16px; max-width: 400px;">
                            <label for="confirm-password" style="display: block; font-size: 14px; font-weight: 600; margin-bottom: 8px;">비밀번호 확인</label>
                            <input type="password" id="confirm-password" @bind="confirmPassword" placeholder="현재 계정 비밀번호" style="width: 100%; padding: 8px; border: 1px solid #e5e7eb; border-radius: 4px; font-size: 14px;" />
                        </div>
                        <button type="submit" disabled="@isSubmitting2Fa" style="padding: 10px 20px; background: #ef4444; color: #FFFFFF; border: none; border-radius: 4px; font-weight: 600; cursor: pointer;">
                            @(isSubmitting2Fa ? "처리 중..." : "2FA 비활성화하기")
                        </button>
                    </form>
                </div>
            }
            else
            {
                <div style="border: 1px solid #e5e7eb; border-radius: 6px; padding: 20px; background: #ffffff;">
                    <h3 style="font-size: 16px; font-weight: 600; margin-top: 0; margin-bottom: 8px;">2단계 인증(2FA) 설정</h3>
                    <p style="font-size: 14px; color: #6b7280; margin-bottom: 20px; line-height: 1.5;">
                        TOTP 표준을 지원하는 OTP 앱(Google Authenticator, Microsoft Authenticator, Authy 등)을 사용하여 계정의 보안을 한층 더 높일 수 있습니다.
                    </p>

                    @if (!isSetupInitiated)
                    {
                        <button type="button" @onclick="Initiate2FaSetup" disabled="@isSubmitting2Fa" style="padding: 10px 20px; background: #2563eb; color: #FFFFFF; border: none; border-radius: 4px; font-weight: 600; cursor: pointer;">
                            @(isSubmitting2Fa ? "준비 중..." : "2FA 활성화 시작하기")
                        </button>
                    }
                    else
                    {
                        <div style="display: flex; flex-direction: column; gap: 24px; margin-top: 16px; border-top: 1px solid #e5e7eb; padding-top: 24px;">
                            <div>
                                <h4 style="font-size: 14px; font-weight: 600; margin-bottom: 8px;">1단계: OTP 앱에서 아래 QR 코드를 스캔하세요.</h4>
                                <div style="display: flex; gap: 24px; align-items: center; flex-wrap: wrap;">
                                    <div id="qrcode-container" style="padding: 12px; background: white; border: 1px solid #e5e7eb; border-radius: 6px; width: 224px; height: 224px; display: flex; justify-content: center; align-items: center;">
                                        <!-- QR Code will be drawn here by JS -->
                                    </div>
                                    <div style="flex: 1; min-width: 250px;">
                                        <p style="font-size: 13px; color: #4b5563; margin-top: 0;">
                                            QR 코드를 스캔할 수 없는 경우, 아래의 보안 비밀키를 직접 수동으로 추가하십시오.
                                        </p>
                                        <div style="background: #f3f4f6; padding: 10px; border-radius: 4px; font-family: monospace; font-size: 14px; word-break: break-all; border: 1px solid #e5e7eb; display: inline-block;">
                                            @tempSecretKey
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div style="max-width: 400px;">
                                <h4 style="font-size: 14px; font-weight: 600; margin-bottom: 8px;">2단계: OTP 앱에 표시된 6자리 코드를 입력하세요.</h4>
                                <form @submit:preventDefault="true" @onsubmit="Enable2FaAsync">
                                    <div style="margin-bottom: 16px;">
                                        <input type="text" @bind="otpVerificationCode" placeholder="6자리 숫자" maxlength="6" style="width: 100%; padding: 8px; border: 1px solid #e5e7eb; border-radius: 4px; font-size: 16px; letter-spacing: 4px; text-align: center; font-weight: bold;" />
                                    </div>
                                    <div style="display: flex; gap: 8px;">
                                        <button type="submit" disabled="@isSubmitting2Fa" style="padding: 10px 20px; background: #16a34a; color: #FFFFFF; border: none; border-radius: 4px; font-weight: 600; cursor: pointer;">
                                            @(isSubmitting2Fa ? "검증 중..." : "인증 및 2FA 활성화")
                                        </button>
                                        <button type="button" @onclick="Cancel2FaSetup" style="padding: 10px 20px; background: #e5e7eb; color: #374151; border: none; border-radius: 4px; font-weight: 600; cursor: pointer;">
                                            취소
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }

            <hr style="border: 0; border-top: 1px solid #e5e7eb; margin: 32px 0;" />

            <h3 style="font-size: 18px; font-weight: 600; margin-bottom: 16px;">접속 세션 관리</h3>
            <p style="font-size: 14px; color: #6b7280; margin-bottom: 20px; line-height: 1.5;">
                현재 귀하의 계정으로 로그인된 모든 기기 및 브라우저 세션 목록입니다. 의심스러운 기기가 있다면 원격으로 로그아웃 시킬 수 있습니다.
            </p>

            @if (isLoadingSessions)
            {
                <p style="color: #6b7280; font-size: 14px;">세션 목록을 불러오는 중...</p>
            }
            else if (activeSessions.Count == 0)
            {
                <p style="color: #6b7280; font-size: 14px;">활성화된 세션이 없습니다.</p>
            }
            else
            {
                <div style="display: flex; flex-direction: column; gap: 16px;">
                    @foreach (var session in activeSessions)
                    {
                        var isCurrent = session.Id == currentSessionId;
                        <div style="padding: 16px; border: 1px solid @(isCurrent ? "#bfdbfe" : "#e5e7eb"); border-radius: 6px; display: flex; justify-content: space-between; align-items: center; background: @(isCurrent ? "#f0f9ff" : "#ffffff");">
                            <div>
                                <div style="display: flex; align-items: center; gap: 8px; font-weight: 600; font-size: 14px; margin-bottom: 4px;">
                                    <span>📱 @FormatUserAgent(session.UserAgent)</span>
                                    @if (isCurrent)
                                    {
                                        <span style="background: #2563eb; color: #ffffff; padding: 2px 6px; border-radius: 4px; font-size: 10px; font-weight: bold;">현재 세션</span>
                                    }
                                </div>
                                <div style="font-size: 13px; color: #4b5563; margin-bottom: 4px;">
                                    IP 주소: @session.IpAddress
                                </div>
                                <div style="font-size: 12px; color: #9ca3af;">
                                    최근 활동: @session.LastActiveAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm") (최초 로그인: @session.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm"))
                                </div>
                            </div>
                            @if (!isCurrent)
                            {
                                <button type="button" @onclick="() => RevokeSessionAsync(session.Id)" style="padding: 6px 12px; background: #ef4444; color: #ffffff; border: none; border-radius: 4px; font-size: 12px; font-weight: 600; cursor: pointer;">
                                    세션 종료
                                </button>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private string activeTab = "ssh"; // SSH Keys Tab is active by default
    private bool isLoadingKeys = true;
    private bool isSubmitting = false;

    private string? errorMessage;
    private string? successMessage;

    private string newKeyName = "";
    private string newPublicKey = "";

    private List<SshKey> sshKeys = new();

    // 2FA 관련 상태 변수들
    private bool isLoading2Fa = true;
    private bool isSubmitting2Fa = false;
    private bool isTwoFactorEnabled = false;
    private bool isSetupInitiated = false;
    private string? tempSecretKey;
    private string? otpAuthUri;
    private string otpVerificationCode = "";
    private string[]? recoveryCodesToShow;
    private string confirmPassword = "";

    // 세션 관련 상태 변수들
    private List<UserSessionDto> activeSessions = new();
    private string? currentSessionId;
    private bool isLoadingSessions = true;

    private async Task SwitchTab(string tab)
    {
        activeTab = tab;
        errorMessage = null;
        successMessage = null;
        if (tab == "2fa")
        {
            await Task.WhenAll(Load2FaStatusAsync(), LoadSessionsAsync());
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadKeysAsync();
    }

    private HttpClient CreateHttpClient()
    {
        var client = new HttpClient();
        client.BaseAddress = new Uri(Navigation.BaseUri);
        if (HttpContextAccessor.HttpContext?.Request.Headers.TryGetValue("Cookie", out var cookie) == true)
        {
            client.DefaultRequestHeaders.Add("Cookie", cookie.ToString());
        }
        return client;
    }

    private async Task LoadKeysAsync()
    {
        isLoadingKeys = true;
        try
        {
            using var client = CreateHttpClient();
            var response = await client.GetFromJsonAsync<List<SshKey>>("api/sshkeys");
            if (response != null)
            {
                sshKeys = response;
            }
        }
        catch (Exception)
        {
            errorMessage = "An error occurred while loading SSH keys.";
        }
        finally
        {
            isLoadingKeys = false;
        }
    }

    private void HandleKeyInput()
    {
        // Auto-populate comment if Name is empty
        if (!string.IsNullOrWhiteSpace(newPublicKey) && string.IsNullOrWhiteSpace(newKeyName))
        {
            var parts = newPublicKey.Trim().Split(' ', 3);
            if (parts.Length >= 3)
            {
                var comment = parts[2].Trim();
                if (!string.IsNullOrWhiteSpace(comment))
                {
                    newKeyName = comment;
                }
            }
        }
    }

    private async Task RegisterKeyAsync()
    {
        errorMessage = null;
        successMessage = null;

        if (string.IsNullOrWhiteSpace(newPublicKey))
        {
            errorMessage = "Invalid key format. Only Ed25519, ECDSA, and RSA (3072 bits or higher) keys are supported.";
            return;
        }

        isSubmitting = true;
        try
        {
            using var client = CreateHttpClient();
            var response = await client.PostAsJsonAsync("api/sshkeys", new RegisterSshKeyRequest(newKeyName, newPublicKey));
            
            if (response.IsSuccessStatusCode)
            {
                var addedKeyName = string.IsNullOrWhiteSpace(newKeyName) ? "SSH key" : newKeyName;
                successMessage = $"SSH key \"{addedKeyName}\" was successfully added.";
                newKeyName = "";
                newPublicKey = "";
                await LoadKeysAsync();
            }
            else
            {
                var errObj = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                errorMessage = errObj?.Message ?? "An error occurred while adding the key. Please try again.";
            }
        }
        catch (Exception)
        {
            errorMessage = "An error occurred while adding the key. Please try again.";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task DeleteKeyAsync(SshKey key)
    {
        errorMessage = null;
        successMessage = null;

        var message = $"Delete SSH Key: Are you sure you want to permanently delete the SSH key \"{key.Label}\"?";
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", message);
        if (!confirmed)
        {
            return;
        }

        try
        {
            using var client = CreateHttpClient();
            var response = await client.DeleteAsync($"api/sshkeys/{key.Id}");
            if (response.IsSuccessStatusCode)
            {
                await LoadKeysAsync();
            }
            else
            {
                errorMessage = "Failed to delete the SSH key.";
            }
        }
        catch (Exception)
        {
            errorMessage = "An error occurred while deleting the SSH key.";
        }
    }

    private string GetKeyType(string publicKey)
    {
        if (publicKey.StartsWith("ssh-rsa")) return "RSA";
        if (publicKey.StartsWith("ssh-ed25519")) return "Ed25519";
        if (publicKey.StartsWith("ecdsa-sha2-")) return "ECDSA";
        return "Unknown";
    }

