@page "/{username}/{repoName}"
@page "/{username}/{repoName}/tree/{branch}"
@page "/{username}/{repoName}/tree/{branch}/{*path}"
@using Microsoft.JSInterop
@using Microsoft.EntityFrameworkCore
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer
@inject Aristokeides.Api.Services.GitBrowserService GitService
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthState
@inject NavigationManager NavManager
@inject Aristokeides.Api.Services.Ssh.SshUrlHelper SshUrlHelper
@inject Microsoft.JSInterop.IJSRuntime JSRuntime
@inject Aristokeides.Api.Data.AppDbContext DbContext

<PageTitle>@RepoName - Aristokeides</PageTitle>

@if (string.IsNullOrEmpty(errorMessage))
{
    <div class="repo-header" style="margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid #e5e7eb;">
        <h1 style="margin: 0; font-size: 24px; font-weight: 600;">@Username / @RepoName</h1>
        <div style="margin-top: 16px; display: flex; gap: 16px;">
            <a href="/@Username/@RepoName" style="color: var(--accent, #2563eb); text-decoration: none; font-weight: 500; border-bottom: 2px solid var(--accent, #2563eb); padding-bottom: 4px;">Code</a>
            <a href="/@Username/@RepoName/issues" style="color: #4b5563; text-decoration: none;">Issues</a>
            @if (isOwner)
            {
                <a href="/@Username/@RepoName/settings" style="color: #4b5563; text-decoration: none;">Settings</a>
            }
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger" style="background: var(--destructive); color: white; padding: 16px; border-radius: 4px;">
        @errorMessage
    </div>
}
else if (isEmptyRepo)
{
    <div style="text-align: center; margin-top: 48px;">
        <h2>빈 저장소입니다</h2>
        <p>아직 커밋된 파일이 없습니다. Git 클라이언트를 사용하여 코드를 푸시해 주세요.</p>
        
        <div style="margin-bottom: 16px;">
            <div style="display: inline-flex; align-items: center; gap: 8px; background: var(--secondary); padding: 4px; border-radius: 4px; border: 1px solid #e5e7eb;">
                <button type="button" @onclick='() => SetProtocol("HTTP")' style="padding: 4px 8px; border-radius: 4px; border: none; font-size: 14px; font-weight: 600; cursor: pointer; background: @(activeProtocol == "HTTP" ? "var(--accent)" : "transparent"); color: @(activeProtocol == "HTTP" ? "white" : "inherit");">HTTP</button>
                <button type="button" @onclick='() => SetProtocol("SSH")' style="padding: 4px 8px; border-radius: 4px; border: none; font-size: 14px; font-weight: 600; cursor: pointer; background: @(activeProtocol == "SSH" ? "var(--accent)" : "transparent"); color: @(activeProtocol == "SSH" ? "white" : "inherit");">SSH</button>
                <span style="font-family: monospace; font-size: 13px; padding: 4px 8px; background: white; border: 1px solid #e5e7eb; border-radius: 4px; min-width: 250px;">
                    @CurrentCloneUrl
                </span>
                <button type="button" @onclick="CopyUrlToClipboard" style="padding: 4px 8px; border-radius: 4px; border: 1px solid #e5e7eb; background: white; cursor: pointer; position: relative;">
                    📋
                    @if (isCopied)
                    {
                        <span style="position: absolute; bottom: 100%; left: 50%; transform: translateX(-50%); background: #333; color: white; padding: 2px 6px; border-radius: 4px; font-size: 11px; white-space: nowrap; margin-bottom: 4px;">Copied!</span>
                    }
                </button>
            </div>
        </div>

        <pre style="background: var(--secondary); padding: 16px; border-radius: 4px; display: inline-block; text-align: left; font-family: monospace;">
git remote add origin @CurrentCloneUrl
git push -u origin main
        </pre>

        @if (activeProtocol == "SSH")
        {
            <div style="background-color: #eff6ff; color: #1e3a8a; padding: 12px; border-radius: 6px; margin-top: 16px; border: 1px solid #bfdbfe; text-align: left; display: inline-block; max-width: 600px;">
                <h4 style="font-size: 13px; font-weight: 600; margin-bottom: 4px; margin-top: 0;">💡 커스텀 SSH 키를 사용하시나요?</h4>
                <p style="font-size: 12px; margin: 0;">
                    기본 키(<code style="background: #dbeafe; padding: 1px 3px; border-radius: 3px;">id_rsa</code> 등)가 아닌 경우 인증에 실패하여 패스워드를 요구할 수 있습니다.
                    다음 명령어로 키와 <strong>IdentitiesOnly=yes</strong> 옵션을 명시적으로 지정하세요:
                </p>
                <pre style="background: #1e3a8a; color: #eff6ff; padding: 8px; border-radius: 4px; margin-top: 8px; margin-bottom: 0; font-size: 11px;">GIT_SSH_COMMAND="ssh -i ~/.ssh/my_custom_key -o IdentitiesOnly=yes" git push -u origin main</pre>
            </div>
        }
    </div>
}
else
{
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <div>
            <select @onchange="OnBranchChanged" style="padding: 8px; border-radius: 4px;">
                @foreach (var b in branches)
                {
                    <option value="@b" selected="@(b == Branch)">@b</option>
                }
            </select>
            <span style="margin-left: 16px;">
                <a href="/@Username/@RepoName/commits/@Branch" style="font-weight: 600;">커밋 내역 보기 (View Commits)</a>
            </span>
        </div>

        <div>
            <div style="display: inline-flex; align-items: center; gap: 8px; background: var(--secondary); padding: 4px; border-radius: 4px; border: 1px solid #e5e7eb;">
                <button type="button" @onclick='() => SetProtocol("HTTP")' style="padding: 4px 8px; border-radius: 4px; border: none; font-size: 14px; font-weight: 600; cursor: pointer; background: @(activeProtocol == "HTTP" ? "var(--accent)" : "transparent"); color: @(activeProtocol == "HTTP" ? "white" : "inherit");">HTTP</button>
                <button type="button" @onclick='() => SetProtocol("SSH")' style="padding: 4px 8px; border-radius: 4px; border: none; font-size: 14px; font-weight: 600; cursor: pointer; background: @(activeProtocol == "SSH" ? "var(--accent)" : "transparent"); color: @(activeProtocol == "SSH" ? "white" : "inherit");">SSH</button>
                <span style="font-family: monospace; font-size: 13px; padding: 4px 8px; background: white; border: 1px solid #e5e7eb; border-radius: 4px; min-width: 250px;">
                    @CurrentCloneUrl
                </span>
                <button type="button" @onclick="CopyUrlToClipboard" style="padding: 4px 8px; border-radius: 4px; border: 1px solid #e5e7eb; background: white; cursor: pointer; position: relative;">
                    📋
                    @if (isCopied)
                    {
                        <span style="position: absolute; bottom: 100%; left: 50%; transform: translateX(-50%); background: #333; color: white; padding: 2px 6px; border-radius: 4px; font-size: 11px; white-space: nowrap; margin-bottom: 4px;">Copied!</span>
                    }
                </button>
            </div>
            @if (activeProtocol == "SSH")
            {
                <div style="font-size: 11px; color: #6b7280; margin-top: 4px; text-align: right;">
                    커스텀 키 사용 시 <code style="background: #f3f4f6; padding: 1px 3px; border-radius: 2px;">GIT_SSH_COMMAND="ssh -i /path/to/key -o IdentitiesOnly=yes"</code> 환경변수 필요
                </div>
            }
        </div>
    </div>

    <div style="margin-bottom: 16px; font-weight: 600; background: var(--secondary); padding: 12px; border-radius: 4px;">
        <a href="/@Username/@RepoName/tree/@Branch">@RepoName</a> / 
        @if (!string.IsNullOrEmpty(Path))
        {
            var parts = Path.Split('/');
            var currentPath = "";
            for (int i = 0; i < parts.Length; i++)
            {
                currentPath += (i == 0 ? "" : "/") + parts[i];
                <a href="/@Username/@RepoName/tree/@Branch/@currentPath">@parts[i]</a>
                if (i < parts.Length - 1)
                {
                    <span> / </span>
                }
            }
        }
    </div>

    <div style="border: 1px solid #e5e7eb; border-radius: 4px;">
        @if (!string.IsNullOrEmpty(Path))
        {
            var parentPath = "";
            var lastSlashIndex = Path.LastIndexOf('/');
            if (lastSlashIndex >= 0)
                parentPath = Path.Substring(0, lastSlashIndex);

            <div style="padding: 12px; border-bottom: 1px solid #e5e7eb;">
                <a href="/@Username/@RepoName/tree/@Branch/@parentPath">.. (상위 디렉토리)</a>
            </div>
        }

        @foreach (var entry in entries)
        {
            <div style="padding: 12px; border-bottom: 1px solid #e5e7eb; display: flex;">
                @if (entry.IsFolder)
                {
                    <span>📁 </span>
                    <a href="/@Username/@RepoName/tree/@Branch/@entry.Path" style="margin-left: 8px;">@entry.Name</a>
                }
                else
                {
                    <span>📄 </span>
                    <a href="/@Username/@RepoName/blob/@Branch/@entry.Path" style="margin-left: 8px;">@entry.Name</a>
                }
            </div>
        }
    </div>
}

@code {
    [Parameter] public string Username { get; set; } = default!;
    [Parameter] public string RepoName { get; set; } = default!;
    [Parameter] public string? Branch { get; set; }
    [Parameter] public string? Path { get; set; }

    private string errorMessage = "";
    private bool isEmptyRepo = false;
    private bool isOwner = false;
    private List<string> branches = new();
    private List<Aristokeides.Api.Services.GitTreeEntry> entries = new();
    private string? repoPath;

    private string activeProtocol = "HTTP";
    private bool isCopied = false;

    private string CurrentCloneUrl => activeProtocol == "SSH" 
        ? SshUrlHelper.GetSshCloneUrl(Username, RepoName) 
        : SshUrlHelper.GetHttpCloneUrl(Username, RepoName);

    private void SetProtocol(string protocol)
    {
        activeProtocol = protocol;
    }

    private async Task CopyUrlToClipboard()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", CurrentCloneUrl);
            isCopied = true;
            StateHasChanged();
            
            await Task.Delay(2000);
            isCopied = false;
            StateHasChanged();
        }
        catch
        {
            // Ignore
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var user = authState.User;
        if (!user.Identity?.IsAuthenticated ?? true)
        {
            errorMessage = "인증되지 않았습니다.";
            return;
        }

        var userIdClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
        if (userIdClaim == null || !int.TryParse(userIdClaim.Value, out int userId))
        {
            errorMessage = "사용자 정보를 확인할 수 없습니다.";
            return;
        }

        repoPath = await GitService.ValidateAccessAsync(userId, Username, RepoName);
        if (repoPath == null || !System.IO.Directory.Exists(repoPath))
        {
            errorMessage = "저장소를 찾을 수 없거나 접근 권한이 없습니다.";
            return;
        }

        try
        {
            var repository = await DbContext.Repositories
                .FirstOrDefaultAsync(r => r.Owner!.Username == Username && r.Name == RepoName);
            isOwner = repository?.OwnerId == userId;

            branches = GitService.GetBranches(repoPath);
            if (!branches.Any())
            {
                isEmptyRepo = true;
                return;
            }

            if (string.IsNullOrEmpty(Branch))
            {
                Branch = GitService.GetDefaultBranch(repoPath);
                if (string.IsNullOrEmpty(Branch))
                {
                    isEmptyRepo = true;
                    return;
                }
            }

            if (!branches.Contains(Branch))
            {
                errorMessage = "항목을 찾을 수 없습니다. 브랜치나 경로가 올바른지 확인해 주세요.";
                return;
            }

            entries = GitService.GetTreeEntries(repoPath, Branch, Path ?? "");
        }
        catch (LibGit2Sharp.NotFoundException)
        {
            errorMessage = "항목을 찾을 수 없습니다. 브랜치나 경로가 올바른지 확인해 주세요.";
        }
        catch (Exception ex)
        {
            errorMessage = "오류가 발생했습니다: " + ex.Message;
        }
    }

    private void OnBranchChanged(ChangeEventArgs e)
    {
        var newBranch = e.Value?.ToString();
        if (!string.IsNullOrEmpty(newBranch))
        {
            NavManager.NavigateTo($"/{Username}/{RepoName}/tree/{newBranch}");
        }
    }
}
