@page "/{username}/{repoName}/issues"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer
@inject Aristokeides.Api.Services.IssueService IssueService
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthState
@inject NavigationManager NavManager

<PageTitle>Issues - @RepoName - Aristokeides</PageTitle>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div style="background: var(--destructive); color: white; padding: 16px; border-radius: 4px;">
        @errorMessage
    </div>
}
else if (repository == null)
{
    <p>Loading...</p>
}
else
{
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <div>
            <a href="/@Username/@RepoName">Code</a>
            <span style="margin: 0 8px; color: #9CA3AF;">|</span>
            <span style="font-weight: 600;">Issues</span>
        </div>
        <a href="/@Username/@RepoName/issues/new"
           style="background: var(--accent); color: white; padding: 8px 16px; border-radius: 4px; text-decoration: none; font-weight: 500;">
            Create Issue
        </a>
    </div>

    @if (!issues.Any())
    {
        <div style="text-align: center; margin-top: 48px;">
            <h2 style="font-size: 24px;">No issues found</h2>
            <p style="color: #6B7280;">Get started by creating a new issue for this repository.</p>
        </div>
    }
    else
    {
        <div style="display: flex; overflow-x: auto; gap: 16px; padding: 24px 0;">
            @foreach (var column in columns)
            {
                var columnIssues = issues.Where(i => i.ColumnId == column.Id).ToList();
                <div style="flex-shrink: 0; width: 300px; background: var(--secondary); border-radius: 4px; padding: 16px;"
                     @ondrop="() => HandleDrop(column.Id)"
                     @ondragover:preventDefault>

                    <div style="font-weight: 600; font-size: 14px; margin-bottom: 16px; display: flex; justify-content: space-between; align-items: center;">
                        <span>@column.Name</span>
                        <span style="background: #E5E7EB; border-radius: 12px; padding: 2px 8px; font-size: 12px; font-weight: 500;">@columnIssues.Count</span>
                    </div>

                    @foreach (var issue in columnIssues)
                    {
                        <div draggable="true"
                             @ondragstart="() => HandleDragStart(issue.Id)"
                             @onclick="() => NavigateToIssue(issue.LocalId)"
                             style="background: var(--dominant); border: 1px solid #E5E7EB; border-radius: 4px; padding: 12px; margin-bottom: 8px; cursor: grab; @(draggedIssueId == issue.Id ? "opacity: 0.5;" : "")">
                            <div style="font-weight: 500;">@issue.Title</div>
                            <div style="font-size: 12px; color: #6B7280; margin-top: 4px;">
                                #@issue.LocalId
                                @if (issue.Assignee != null)
                                {
                                    <span> · @issue.Assignee.Username</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
}

@if (!string.IsNullOrEmpty(statusMessage))
{
    <div style="position: fixed; bottom: 16px; right: 16px; background: var(--destructive); color: white; padding: 12px 16px; border-radius: 4px;">
        @statusMessage
    </div>
}

@code {
    [Parameter] public string Username { get; set; } = default!;
    [Parameter] public string RepoName { get; set; } = default!;

    private string errorMessage = "";
    private string statusMessage = "";
    private Aristokeides.Api.Models.Repository? repository;
    private List<Aristokeides.Api.Models.BoardColumn> columns = new();
    private List<Aristokeides.Api.Models.Issue> issues = new();
    private Guid? draggedIssueId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var user = authState.User;
        if (!user.Identity?.IsAuthenticated ?? true)
        {
            errorMessage = "인증되지 않았습니다.";
            return;
        }

        repository = await IssueService.GetRepositoryAsync(Username, RepoName);
        if (repository == null)
        {
            errorMessage = "저장소를 찾을 수 없거나 접근 권한이 없습니다.";
            return;
        }

        await LoadBoardAsync();
    }

    private async Task LoadBoardAsync()
    {
        columns = await IssueService.GetBoardColumnsAsync(repository!.Id);
        issues = await IssueService.GetIssuesAsync(repository.Id);
    }

    private void HandleDragStart(Guid issueId)
    {
        draggedIssueId = issueId;
    }

    private async Task HandleDrop(Guid columnId)
    {
        if (draggedIssueId == null) return;

        var success = await IssueService.UpdateIssueStatusAsync(draggedIssueId.Value, columnId);
        if (success)
        {
            await LoadBoardAsync();
            statusMessage = "";
        }
        else
        {
            statusMessage = "Failed to update issue status. Please try again.";
        }

        draggedIssueId = null;
    }

    private void NavigateToIssue(int localId)
    {
        NavManager.NavigateTo($"/{Username}/{RepoName}/issues/{localId}");
    }
}
