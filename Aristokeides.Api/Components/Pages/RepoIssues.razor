@page "/{Username}/{RepoName}/issues"
@using Aristokeides.Api.Data
@using Aristokeides.Api.Models
@using Aristokeides.Api.Services
@using Microsoft.EntityFrameworkCore
@inject IssueService IssueService
@inject AppDbContext DbContext
@inject NavigationManager Navigation
@rendermode Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer

<PageTitle>@Username/@RepoName - Issues</PageTitle>

<div class="repo-header" style="margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid #e5e7eb;">
    <h1 style="margin: 0; font-size: 24px; font-weight: 600;">@Username / @RepoName</h1>
    <div style="margin-top: 16px; display: flex; gap: 16px;">
        <a href="/@Username/@RepoName" style="color: #4b5563; text-decoration: none;">Code</a>
        <a href="/@Username/@RepoName/issues" style="color: #2563eb; text-decoration: none; font-weight: 500;">Issues</a>
    </div>
</div>

<div class="issues-container" style="max-width: 1200px; margin: 0 auto;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <h2 style="margin: 0; font-size: 20px; font-weight: 600;">Kanban Board</h2>
        <button @onclick="NavigateToNewIssue" style="background-color: #2563eb; color: white; border: none; padding: 8px 16px; border-radius: 4px; font-weight: 500; cursor: pointer;">
            Create Issue
        </button>
    </div>

    @if (errorMessage != null)
    {
        <div style="background-color: #fee2e2; color: #ef4444; padding: 12px; border-radius: 4px; margin-bottom: 16px;">
            @errorMessage
        </div>
    }

    @if (isLoading)
    {
        <p>Loading board...</p>
    }
    else if (repository == null)
    {
        <p>Repository not found.</p>
    }
    else
    {
        <div class="kanban-board" style="display: flex; overflow-x: auto; gap: 16px; padding-bottom: 16px;">
            @foreach (var column in columns)
            {
                <div class="kanban-column" style="background-color: #f3f4f6; border-radius: 6px; width: 300px; flex-shrink: 0; padding: 12px; display: flex; flex-direction: column;"
                     ondragover="event.preventDefault()" 
                     @ondrop="@(async () => await HandleDrop(column.Id))">
                    
                    <h3 style="margin-top: 0; margin-bottom: 12px; font-size: 14px; font-weight: 600; color: #374151;">@column.Name</h3>
                    
                    <div class="kanban-cards" style="display: flex; flex-direction: column; gap: 8px; flex-grow: 1;">
                        @foreach (var issue in issues.Where(i => i.ColumnId == column.Id).OrderBy(i => i.LocalId))
                        {
                            <div class="kanban-card" style="background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 4px; padding: 12px; cursor: grab; opacity: @(draggingIssue?.Id == issue.Id ? 0.5 : 1);"
                                 draggable="true" 
                                 @ondragstart="@(() => HandleDragStart(issue))"
                                 @onclick="@(() => NavigateToIssue(issue.LocalId))">
                                
                                <div style="font-size: 14px; font-weight: 500; margin-bottom: 8px;">@issue.Title</div>
                                <div style="display: flex; justify-content: space-between; font-size: 12px; color: #6b7280;">
                                    <span>#@issue.LocalId</span>
                                    @if (issue.Assignee != null)
                                    {
                                        <span>@issue.Assignee.Username</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public string Username { get; set; } = "";

    [Parameter]
    public string RepoName { get; set; } = "";

    private Repository? repository;
    private List<BoardColumn> columns = new();
    private List<Issue> issues = new();
    private bool isLoading = true;
    private string? errorMessage;

    private Issue? draggingIssue;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            repository = await DbContext.Repositories
                .Include(r => r.Owner)
                .FirstOrDefaultAsync(r => r.Owner!.Username == Username && r.Name == RepoName);

            if (repository != null)
            {
                columns = await IssueService.GetBoardColumnsAsync(repository.Id);
                issues = await IssueService.GetIssuesAsync(repository.Id);
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Failed to load board: " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void HandleDragStart(Issue issue)
    {
        draggingIssue = issue;
    }

    private async Task HandleDrop(Guid targetColumnId)
    {
        if (draggingIssue != null && draggingIssue.ColumnId != targetColumnId)
        {
            try
            {
                await IssueService.UpdateIssueStatusAsync(draggingIssue.Id, targetColumnId);
                // Update local state without full reload
                draggingIssue.ColumnId = targetColumnId;
            }
            catch (Exception ex)
            {
                errorMessage = "Failed to update issue status: " + ex.Message;
            }
        }
        draggingIssue = null;
    }

    private void NavigateToNewIssue()
    {
        Navigation.NavigateTo($"/{Username}/{RepoName}/issues/new");
    }

    private void NavigateToIssue(int localId)
    {
        Navigation.NavigateTo($"/{Username}/{RepoName}/issues/{localId}");
    }
}
