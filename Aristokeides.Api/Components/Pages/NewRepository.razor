@page "/repositories/new"
@using System.Text.RegularExpressions
@using Aristokeides.Api.Data
@using Aristokeides.Api.Models
@using Aristokeides.Api.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@attribute [Authorize]
@inject AppDbContext DbContext
@inject RepositoryCreationChannel CreationChannel
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@rendermode Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer

<PageTitle>새 저장소 만들기 - Aristokeides</PageTitle>

<div style="max-width: 600px; margin: 40px auto; padding: 32px; background: var(--dominant, #FFFFFF); border: 1px solid #e5e7eb; border-radius: 8px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
    <h2 style="font-size: 24px; font-weight: 600; margin-top: 0; margin-bottom: 8px;">새 저장소 만들기</h2>
    <p style="color: #6b7280; font-size: 14px; margin-bottom: 24px;">저장소는 코드 내역, 이슈, 풀 리퀘스트 등을 포함합니다.</p>

    @if (errorMessage != null)
    {
        <div style="background-color: #fee2e2; color: #ef4444; padding: 12px 16px; border-radius: 6px; border: 1px solid #fca5a5; margin-bottom: 20px; font-size: 14px;">
            @errorMessage
        </div>
    }

    <EditForm Model="@model" OnValidSubmit="HandleSubmit" FormName="NewRepoForm">
        <DataAnnotationsValidator />

        <!-- Owner (read-only) -->
        <div style="margin-bottom: 16px;">
            <label style="display: block; font-size: 14px; font-weight: 600; margin-bottom: 6px; color: #374151;">소유자</label>
            <input type="text" value="@currentUsername" disabled style="width: 100%; padding: 8px 12px; border: 1px solid #d1d5db; border-radius: 6px; background: #f9fafb; color: #6b7280; font-size: 14px;" />
        </div>

        <!-- Repository Name -->
        <div style="margin-bottom: 16px;">
            <label for="repo-name" style="display: block; font-size: 14px; font-weight: 600; margin-bottom: 6px; color: #374151;">저장소 이름</label>
            <InputText id="repo-name" @bind-Value="model.Name" placeholder="예: my-awesome-project" style="width: 100%; padding: 8px 12px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 14px; box-sizing: border-box;" />
            <ValidationMessage For="@(() => model.Name)" style="color: #ef4444; font-size: 12px; margin-top: 4px; display: block;" />
        </div>

        <!-- Description -->
        <div style="margin-bottom: 20px;">
            <label for="description" style="display: block; font-size: 14px; font-weight: 600; margin-bottom: 6px; color: #374151;">설명 <span style="font-weight: 400; color: #9ca3af;">(선택)</span></label>
            <InputTextArea id="description" @bind-Value="model.Description" placeholder="저장소에 대한 간단한 설명을 입력하세요." rows="3" style="width: 100%; padding: 8px 12px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 14px; font-family: inherit; box-sizing: border-box; resize: vertical;" />
        </div>

        <!-- Privacy Selector -->
        <div style="margin-bottom: 24px; padding: 16px; border: 1px solid #e5e7eb; border-radius: 6px; background: #f9fafb;">
            <div style="display: flex; align-items: flex-start; gap: 12px;">
                <InputCheckbox id="is-private" @bind-Value="model.IsPrivate" style="margin-top: 4px; width: 16px; height: 16px; cursor: pointer;" />
                <div>
                    <label for="is-private" style="font-weight: 600; font-size: 14px; color: #374151; cursor: pointer; display: block;">비공개 저장소로 설정 (Private)</label>
                    <span style="font-size: 12px; color: #6b7280; display: block; margin-top: 2px;">회원님과 회원님이 명시적으로 허용한 사람만 이 저장소를 볼 수 있습니다. 비활성화 시 누구나 접근 가능한 공개 저장소(Public)가 됩니다.</span>
                </div>
            </div>
        </div>

        <!-- Submit and Cancel -->
        <div style="display: flex; gap: 12px; justify-content: flex-end;">
            <a href="/dashboard" style="display: inline-flex; align-items: center; justify-content: center; padding: 10px 20px; border: 1px solid #d1d5db; border-radius: 6px; color: #374151; font-weight: 600; font-size: 14px; text-decoration: none; background: #ffffff;">
                취소
            </a>
            <button type="submit" disabled="@isSubmitting" style="display: inline-flex; align-items: center; justify-content: center; padding: 10px 20px; background: var(--accent, #2563eb); border: none; border-radius: 6px; color: white; font-weight: 600; font-size: 14px; cursor: @(isSubmitting ? "not-allowed" : "pointer"); opacity: @(isSubmitting ? 0.7 : 1);">
                @(isSubmitting ? "저장소 생성 중..." : "새 저장소 만들기")
            </button>
        </div>
    </EditForm>
</div>

@code {
    private string currentUsername = "";
    private int currentUserId;
    private bool isSubmitting = false;
    private string? errorMessage;

    private RepoFormModel model = new();

    public class RepoFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "저장소 이름을 입력해 주세요.")]
        [System.ComponentModel.DataAnnotations.StringLength(100, ErrorMessage = "저장소 이름은 100자 이하이어야 합니다.")]
        [System.ComponentModel.DataAnnotations.RegularExpression(@"^[a-zA-Z0-9_\-]+$", ErrorMessage = "저장소 이름은 영문자, 숫자, 대시(-), 언더스코어(_)만 포함할 수 있습니다.")]
        public string Name { get; set; } = "";

        public string? Description { get; set; }

        public bool IsPrivate { get; set; } = true;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                currentUsername = user.Identity.Name ?? "";
                var userIdClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
                if (userIdClaim != null)
                {
                    currentUserId = int.Parse(userIdClaim.Value);
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = "사용자 정보를 로드하는 데 실패했습니다. (" + ex.Message + ")";
        }
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            // 중복 검사
            var nameLower = model.Name.ToLower();
            var isDuplicate = await DbContext.Repositories
                .AnyAsync(r => r.OwnerId == currentUserId && r.Name.ToLower() == nameLower);

            if (isDuplicate)
            {
                errorMessage = $"이미 사용 중인 저장소 이름입니다: {model.Name}";
                return;
            }

            // DB 저장소 엔티티 추가
            var repository = new Repository
            {
                Id = Guid.NewGuid(),
                Name = model.Name,
                Description = model.Description,
                OwnerId = currentUserId,
                Status = "Creating",
                IsPrivate = model.IsPrivate,
                PrimaryLanguage = null, // 언어는 첫 커밋 분석 후 설정되거나 빈 값
                CreatedAt = DateTime.UtcNow,
                UpdatedAt = DateTime.UtcNow
            };

            DbContext.Repositories.Add(repository);

            // 기본 칸반 보드 컬럼 추가
            var defaultColumns = new[]
            {
                new BoardColumn { Id = Guid.NewGuid(), RepositoryId = repository.Id, Name = "To Do", Order = 1 },
                new BoardColumn { Id = Guid.NewGuid(), RepositoryId = repository.Id, Name = "In Progress", Order = 2 },
                new BoardColumn { Id = Guid.NewGuid(), RepositoryId = repository.Id, Name = "Done", Order = 3 }
            };
            DbContext.BoardColumns.AddRange(defaultColumns);

            await DbContext.SaveChangesAsync();

            // 백엔드 Git 생성 큐 등록
            await CreationChannel.EnqueueAsync(repository.Id);

            // 완료 후 저장소 페이지로 이동
            Navigation.NavigateTo($"/{currentUsername}/{model.Name}");
        }
        catch (Exception ex)
        {
            errorMessage = $"저장소 생성에 실패했습니다: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
