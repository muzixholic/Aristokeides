@inherits LayoutComponentBase

<div class="page">
    <div class="navbar">
        <div class="nav-left">
            <a href="/" style="font-weight: 600; font-size: 1.25rem;">Aristokeides</a>
            <AuthorizeView>
                <Authorized>
                    <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">대시보드</NavLink>
                </Authorized>
            </AuthorizeView>
        </div>
        <div class="nav-right">
            <AuthorizeView>
                <Authorized>
                    <span>@context.User.Identity?.Name 님</span>
                    <NavLink class="btn-nav-accent" href="/repositories/new">새 저장소 만들기</NavLink>
                    <AuthorizeView Roles="Admin">
                        <Authorized Context="adminContext">
                            <NavLink class="nav-link text-danger" href="/admin/settings">관리자 설정</NavLink>
                        </Authorized>
                    </AuthorizeView>
                    <NavLink class="nav-link" href="/settings">설정</NavLink>
                    <a class="nav-link" href="/api/auth/logout">로그아웃</a>
                </Authorized>
                <NotAuthorized>
                    <NavLink class="nav-link" href="/login">로그인</NavLink>
                    <NavLink class="nav-link" href="/register">회원가입</NavLink>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>

    <main class="main-content">
        @Body
    </main>

    <footer class="footer">
        <div>&copy; @DateTime.Now.Year Aristokeides. All rights reserved.</div>
        <div class="footer-links">
            <a href="/">Home</a>
            <a href="/swagger">Swagger API</a>
        </div>
    </footer>
</div>
